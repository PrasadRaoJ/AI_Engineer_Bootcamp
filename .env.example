GROQ_API_KEY=your_groq_api_key
OPENAI_API_KEY=your_openai_api_key
GOOGLE_API_KEY=your_google_api_key

# ── Active model (change these lines to switch provider) ──────────────────────
# google_genai: LLM_PROVIDER=google_genai  LLM_MODEL=gemini-2.5-flash
# groq:         LLM_PROVIDER=groq          LLM_MODEL=llama-3.3-70b-versatile
# ollama:       LLM_PROVIDER=ollama        LLM_MODEL=llama3.2
#
# llama.cpp (local GGUF models via llama-server):
#   1. Start server:  ~/models/switch-model.sh qwen3-4b
#                     available: qwen3-4b | qwen3-8b | gemma4-12b | phi4 | qwen3-30b
#   2. Set below:     LLM_PROVIDER=openai  LLM_MODEL=local
#   3. Uncomment:     OPENAI_BASE_URL and set OPENAI_API_KEY=none
#   ChatOpenAI reads OPENAI_BASE_URL automatically — no code changes needed.
# OPENAI_BASE_URL=http://localhost:8080/v1

LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
